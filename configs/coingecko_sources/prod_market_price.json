{
    "pipeline_name": "market_analytics_platform",

    "job_name": "prod_coingecko_market_price",

    "job_type": "ingestion",

    "metadata": {
        "source": "coingecko",
        "dataset": "market_price",
        "entity": "cryptocurrency"
    },

    "exec": {
        "type": "ApiReadExecCommand",
        "base_url": "https://api.coingecko.com/api/v3",
        "path": "/coins/markets",
        "pagination": {
            "strategy": "page",
            "page_param": "page"
        },
        "page_size": {
            "param": "per_page",
            "value": 250
        },
        "query_params": {
            "vs_currency": "inr"
        },
        "auth": {
            "type": "api_key",
            "key_env": "COINGECKO_API_KEY",
            "location": "header",
            "name": "x-cg-demo-api-key"
        }
    },

    "destination": {
        "type": "gcs",
        "bucket": "prod-market-analytics-platform-bucket",
        "layer": "staging",
        "format": "parquet",
        "path_template": "{layer}/{source}/{dataset}/{entity}/ingestion_dt={ingestion_dt}/ingestion_ts={ingestion_ts}.{format}"
    }
}