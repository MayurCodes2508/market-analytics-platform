{

        "type": "object",

        "required": ["dest_type", "bucket", "layer", "format", "path_template"],
    

        "properties": {

            "dest_type": {

              "type": "string",
              "const": "GCS"
            },

            "bucket": {

                "type": "string",
                "minLength": 2,
                "maxLength": 50
            },

            "layer": {

                "type": "string",
                "enum": ["dev", "staging", "prod"]
            },

            "format": {

                "type": "string",
                "minLength": 2,
                "maxLength": 50
            },

            "path_template": {
                
                "type": "string",
                "const":"{layer}/{source}/{dataset}/{entity}/ingestion_dt={ingestion_dt}/ingestion_ts={ingestion_ts}.{format}"
            }
        },
        "additionalProperties": false
    }
