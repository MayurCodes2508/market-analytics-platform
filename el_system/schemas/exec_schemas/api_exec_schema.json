{
    "type": "object",
    "required": ["type", "base_url", "path", "pagination", "page_size", "query_params"],
    "properties": {
      "type": { "const": "ApiExecCommand" },
      "base_url": {
        "type": "string",
        "const": "https://api.coingecko.com/api/v3",
        "format": "uri",
        "minLength": 1,
        "maxLength": 50   
      },
        "path": {
          "type": "string",
          "const": "/coins/markets",
          "minLength": 1,
          "maxLength": 50
        },
        "pagination": {
          "type": "object",
          "required": ["strategy"],
          "properties": {
            "strategy": {
              "type": "string",
              "const": "page"
            },
            "page_param": {
              "type": "string",
              "default": "page",
              "pattern": "^[a-z0-9_]+$",
              "minLength": 3,
              "maxLength": 50
            }   
          },
          "additionalProperties": false
        },
        "page_size": {
            "type": "object",
            "required": ["param", "value"],
            "properties": {
                "param": {
                    "type": "string",
                    "const": "per_page"
                },
                "value": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 250
            }
          },
          "additionalProperties": false
        },
        "query_params": {
          "type": "object",
          "required": ["vs_currency"],
          "properties": {
            "vs_currency": {
              "type": "string",
              "enum": ["usd", "eur", "inr"]
            }
          },
          "additionalProperties": { "type": "string" }
        },
        "auth": {
          "type": "object",
          "required": ["type", "key_env", "location", "name"],
          "properties": {
            "type": {
              "type": "string",
              "const": "api_key"
            },
            "key_env": {
              "type": "string",
              "pattern": "^[A-Z0-9_]+$",
              "minLength": 1,
              "maxLength": 50
            },
            "location": { "type": "string", "const": "header" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }           
      },
      "additionalProperties": false
    }
