{
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "type": "object",

    "required": ["job_name", "job_type", "exec"],

    "properties": {

        "job_name": {
            "type": "string",
            "pattern": "^(dev_|prod_)[a-z0-9_]+$",
            "minLength": 7,
            "maxLength": 50
        },

        "system": {
            "type": "string",
            "enum": ["el", "dbt", "metadata"]
        },

        "job_type": {
            "type": "string",
            "enum": ["ingestion", "quality", "transformation"]
        },

        "sub_jobtype": {
            "type": "string",
            "enum": ["api", "dbt"]
        },

        "metadata": {
            "type": "object",
            "properties": {
                "source": {
                    "type": "string",
                    "pattern": "^[a-z0-9_]+$"
                },
                "dataset": {
                    "type": "string",
                    "pattern": "^[a-z0-9_]+$"
                },
                "entity": {
                    "type": "string",
                    "pattern": "^[a-z0-9_]+$"
                }
            },
            "additionalProperties": false
        },

        "exec": {
            "$ref": "exec_schemas/api_exec_schema.json"
        },

        "destination": {
            "$ref": "dest_schemas/gcs_dest_schema.json"
        }
    },

    "allOf": [
        {
            "if": {
                "properties": {
                    "job_type": {"const": "ingestion"}
                }
            },
            "then": {
                "required": ["metadata", "destination"]
            }
        }
    ],
    
    "additionalProperties": false
}