{
    
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "type": "object",

    "required": ["metadata" ,"exec"],

    "properties": {

        "metadata": {

            "type": "object",

            "required": ["source", "dataset", "entity"],

            "properties": {

                "source": {

                    "type": "string",
                    "minLength": 2,
                    "maxLength": 50
                },

                "dataset": {

                    "type": "string",
                    "minLength": 2,
                    "maxLength": 50
                },

                "entity": {

                    "type": "string",
                    "minLength": 2,
                    "maxLength": 50
                }
            },

            "additionalProperties": false
        },

        "exec": {

            "$ref": "exec_schemas/api_exec_schema.json"
        },

        "dest": {

            "$ref": "dest_schemas/gcs_dest_schema.json"
        }
    },

    "allOf": [
        {

            "if": {

                "properties": {

                    "job_type": {"const": "ingestion"}
                }
            },

            "then": {

                "required": ["dest"]
            }
        },

        {

            "if": {

                "properties": {

                    "dest": {

                       "properties": {

                        "dest_type": {"const": "GCS"}
                       } 
                    }
                }
            },

            "then": {

                "required": ["metadata"]
            }
        }
    ],
    
    "additionalProperties": false
}