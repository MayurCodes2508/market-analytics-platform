{
    
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "type": "object",

    "required": ["job_name", "system", "job_type", "sub_jobtype", "exec"],

    "properties": {

        "job_name": {

            "type": "string",
            "pattern": "^(dev_|prod_)[a-z0-9_]+$",
            "minLength": 7,
            "maxLength": 30
        },

        "system": {

            "type": "string",
            "minLength": 1,
            "maxLength": 30
        },

        "job_type": {

            "type": "string",
            "minLength": 1,
            "maxLength": 30
        },

        "sub_jobtype": {

            "type": "string",
            "minLength": 1,
            "maxLength": 30
        },

        "metadata": {

            "type": "object",

            "required": ["source", "dataset", "entity"],

            "properties": {

                "source": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                },

                "dataset": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                },

                "entity": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                }
            },

            "additionalProperties": false
        },

        "exec": {

            "$ref": "exec_schemas/api_exec_schema.json"
        },

        "dest": {

            "$ref": "dest_schemas/gcs_dest_schema.json"
        }
    },

    "allOf": [
        {

            "if": {

                "properties": {

                    "job_type": {"const": "ingestion"}
                }
            },

            "then": {

                "required": ["dest"]
            }
        },

        {

            "if": {

                "properties": {

                    "dest": {

                        
                    }
                }
            },

            "then": {

                "required": ["metadata"]
            }
        }
    ],
    
    "additionalProperties": false
}