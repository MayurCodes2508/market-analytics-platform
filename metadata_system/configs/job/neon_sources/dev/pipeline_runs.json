{
    "job_name": "dev_neon_pipeline_runs",

    "system": "metadata",

    "job_type": "ingestion",

    "sub_jobtype": "db",

    "metadata": {

        "source": "neon",
        "dataset": "pipeline_runs",
        "entity": "pipeline_execution"
    },

    "exec": {

        "exec_type": "DBExecCmd",
        "table": "{dataset}",
        "query": "SELECT * FROM {table} WHERE status != 'RUNNING'",

        "auth": {

            "auth_type": "db_url",
            "key_env": "NEON_DB_URL"
        }
    },

    "dest": {

        "dest_type": "BQ",
        "schema": "dev_metadata",
        "table": "raw_pipeline_runs"
    }
}