{
    
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "type": "object",

    "required": ["metadata", "exec"],

    "properties": {

        "metadata": {

            "type": "object",

            "required": ["source", "dataset", "entity"],

            "properties": {

                "source": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                },

                "dataset": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50
                },

                "entity": {

                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                }
            },

            "additionalProperties": false
        },

        "exec": {

            "anyOf": [

                {"$ref": "exec_cmd_schemas/db_exec_cmd_schema.json"},
                {"$ref": "exec_cmd_schemas/dbt_exec_cmd_schema.json"}
            ]

            
        },

        "dest": {

            "$ref": "dest_schemas/bq_dest_schema.json"
        }
    },

    "additionalProperties": false
}