{

    "metadata": {

        "source": "coingecko",
        "dataset": "market_price",
        "entity": "cryptocurrency"
    },

    "exec": {

        "exec_type": "ApiExecCmd",
        "path": "/coins/markets",
        "pagination": {

            "strategy": "page",
            "page_param": "page"
        },
        "page_size": {

            "param": "per_page",
            "value": 250
        },
        "query_params": {

            "vs_currency": "inr"
        },
        "auth": {

            "auth_type": "api_key",
            "key_env": "COINGECKO_API_KEY",
            "location": "header",
            "name": "x-cg-demo-api-key"
        }
    },

    "dest": {

        "dest_type": "GCS",
        "bucket": "prod-market-analytics-platform-bucket",
        "layer": "staging",
        "format": "parquet",
        "path_template": "{layer}/{source}/{dataset}/{entity}/ingestion_dt={ingestion_dt}/ingestion_ts={ingestion_ts}.{format}"
    }
}