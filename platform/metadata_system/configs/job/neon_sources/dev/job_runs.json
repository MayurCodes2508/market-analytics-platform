{

    "metadata": {

        "source": "neon",
        "dataset": "job_runs",
        "entity": "job_execution"
    },

    "exec": {

        "exec_type": "DBExecCmd",
        "table": "{dataset}",
        "query": "SELECT * FROM {table} WHERE status != 'RUNNING'",

        "auth": {
            
            "auth_type": "db_url",
            "key_env": "NEON_DB_URL"
        }
    },

    "dest": {

        "dest_type": "BQ",
        "schema": "dev_metadata",
        "table": "raw_job_runs"
    }
}