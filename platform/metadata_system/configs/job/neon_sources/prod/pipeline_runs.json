{

    "metadata": {

        "source": "neon",
        "dataset": "pipeline_runs",
        "entity": "pipeline_execution"
    },

    "exec": {

        "exec_type": "DBExecCmd",
        "table": "{dataset}",
        "query": "SELECT * FROM {table} WHERE status != 'RUNNING'",

        "auth": {

            "auth_type": "db_url",
            "key_env": "NEON_DB_URL"
        }
    },

    "dest": {

        "dest_type": "BQ",
        "schema": "prod_metadata",
        "table": "raw_pipeline_runs"
    }
}